rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // 1. GLOBAL SAFETY NET
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // 2. PRIMITIVES & HELPERS
    // -------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function companyId() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('companyId', '') : '';
    }

    function isCompanyAdmin() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin';
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // -------------------------------------------------------------------------
    // 3. VALIDATION HELPERS
    // -------------------------------------------------------------------------

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.email is string;
    }

    function isValidCompany(data) {
      return data.name is string && data.name.size() <= 100 &&
             data.joinCode is string && data.joinCode.size() <= 20 &&
             data.createdBy == request.auth.uid;
    }

    function isValidGoal(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.period in ['1m', '6m', '12m'] &&
             data.status in ['active', 'completed', 'archived'] &&
             data.createdBy is string &&
             data.companyId == companyId();
    }

    function isValidTask(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.assigneeId is string &&
             data.status in ['todo', 'in-progress', 'done', 'stuck'] &&
             data.createdBy is string &&
             data.companyId == companyId();
    }

    function isValidNotification(data) {
      return data.userId is string &&
             data.companyId == companyId() &&
             data.title is string && data.title.size() <= 200 &&
             data.type in ['task', 'message', 'goal'] &&
             data.read == false;
    }

    function isValidMessage(data) {
      return data.senderId == request.auth.uid &&
             data.content is string && data.content.size() <= 2000 &&
             data.companyId == companyId();
    }

    // -------------------------------------------------------------------------
    // 4. COLLECTION RULES
    // -------------------------------------------------------------------------

    // Users
    match /users/{userId} {
      allow get: if isSignedIn();
      allow write: if isOwner(userId);
      allow list: if isSignedIn();
    }

    // Companies
    match /companies/{id} {
      allow get, list, create, update: if isSignedIn();
    }

    // Join Codes
    match /join_codes/{code} {
      allow get, create, update: if isSignedIn();
    }

    // Marketing Assets
    match /marketing_assets/{id} {
      allow read: if isSignedIn() && resource.data.companyId == companyId();
      allow create: if isSignedIn() && incoming().companyId == companyId();
      allow delete: if isCompanyAdmin() && resource.data.companyId == companyId();
    }

    // Goals
    match /goals/{goalId} {
      allow read: if isSignedIn() && resource.data.companyId == companyId();
      allow create: if isCompanyAdmin() && isValidGoal(incoming());
      allow update: if isCompanyAdmin() && isValidGoal(incoming());
      allow delete: if isCompanyAdmin();
    }

    // Tasks
    match /tasks/{taskId} {
      allow read: if isSignedIn() && resource.data.companyId == companyId();
      allow create: if isSignedIn() && isValidTask(incoming());
      allow update: if isSignedIn() && isValidTask(incoming()) && (
        // Assignee can update status or deliverables
        (isOwner(existing().assigneeId) && incoming().diff(existing()).affectedKeys().hasAny(['status', 'deliverables'])) ||
        // Admin or creator can update anything
        isCompanyAdmin() || isOwner(existing().createdBy)
      );
      allow delete: if isCompanyAdmin() || isOwner(existing().createdBy);
    }

    // Messages
    match /messages/{messageId} {
      allow read: if isSignedIn() && resource.data.companyId == companyId();
      allow create: if isSignedIn() && isValidMessage(incoming());
    }

    // Analysis
    match /analysis/{analysisId} {
      allow read: if isOwner(resource.data.userId) || isCompanyAdmin();
      allow create: if isCompanyAdmin();
    }

    // Notifications
    match /notifications/{id} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isSignedIn() && isValidNotification(incoming());
      allow update: if isOwner(resource.data.userId) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['read']);
    }
  }
}
